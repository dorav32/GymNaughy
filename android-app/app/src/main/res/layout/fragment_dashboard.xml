<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStreakCaption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dashboard_streak_label"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvStreakValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        app:layout_constraintTop_toBottomOf="@id/tvStreakCaption"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTodayCaption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dashboard_today_label"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvStreakValue"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTodayWorkoutLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvTodayCaption"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnStartWorkout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/action_start_workout"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTodayWorkoutLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
