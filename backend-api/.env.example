PORT=4000
NODE_ENV=development

# Path to the Firebase service account JSON downloaded in docs/SETUP.md step 1.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Public exercise database (no API key required).
WGER_BASE_URL=https://wger.de/api/v2

# Hours an exercise catalog response is cached in memory before refetching.
EXERCISE_CACHE_TTL_HOURS=6
